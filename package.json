{
  "name": "ai-agent-workshop-monorepo",
  "private": true,
  "version": "0.8.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter @ai-agent-workshop/web dev",
    "dev:dashboard": "pnpm --filter @ai-agent-workshop/dashboard dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @ai-agent-workshop/web build",
    "build:dashboard": "pnpm --filter @ai-agent-workshop/dashboard build",
    "test": "pnpm --filter @ai-agent-workshop/web test",
    "test:e2e": "pnpm --filter @ai-agent-workshop/web test:e2e",
    "lint": "pnpm -r lint",
    "db:migrate": "pnpm --filter @ai-agent-workshop/web db:migrate",
    "db:generate": "pnpm --filter @ai-agent-workshop/web db:generate",
    "db:reset": "pnpm --filter @ai-agent-workshop/web db:reset"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
