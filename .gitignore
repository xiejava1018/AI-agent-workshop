# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (any package in the monorepo, not only repo root)
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js
.next/
out/

# production
build
dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.factory

# runtime scratch: top-level data/ holds cwd sandboxes (keep .gitignore/.gitkeep)
/data/*
!/data/.gitignore
!/data/.gitkeep

# Prisma generated sqlite test artifacts (db files inside prisma/data/ are scratch)
**/prisma/data/

# Comet platform workspace (change state lives in openspec/changes/<name>/.comet/)
/.comet/
openspec/changes/*/.comet/

# Local git worktrees
/.worktrees/

# CodeGraph local index (SQLite knowledge graph)
/.codegraph/

# build/lock scratch
*.bak
test-results/
